{
  "name": "@stoneboyz/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @stoneboyz/domain build",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@react-pdf/renderer": "^4.5.1",
    "@stoneboyz/domain": "workspace:*",
    "express": "^5.0.0",
    "multer": "^2.0.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0"
  }
}
