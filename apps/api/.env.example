# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stoneboyz_crm

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001

# Email (Resend) — optional in development, service logs warning if missing
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=quotes@yourdomain.com

# Cloudflare R2 image storage (optional — local disk fallback used when absent)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=stoneboyz-slabs
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev

# Server
PORT=3001
APP_URL=http://localhost:3001

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001